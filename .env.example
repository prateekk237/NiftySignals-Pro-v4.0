# ═══════════════════════════════════════════════════════════
#  NiftySignals Pro v4.0 — Environment Variables
#  Copy this to .env for local dev, or set in Railway dashboard
# ═══════════════════════════════════════════════════════════

# ── Database (REQUIRED on Railway) ──────────────────────────
# Local: sqlite:///./btst_history.db
# Railway with volume: sqlite:////data/btst_history.db
DATABASE_URL=sqlite:///./btst_history.db

# ── Server ──────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO

# ── CORS (add your frontend URL) ───────────────────────────
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ── NVIDIA NIM (optional — free tier at build.nvidia.com) ───
# LLM-powered sentiment analysis. Falls back to VADER if empty.
NVIDIA_API_KEY=

# ── Feature Flags ───────────────────────────────────────────
ENABLE_LLM=true
ENABLE_SENTIMENT=true
ENABLE_OPTION_CHAIN=true
