# ── NiftySignals Pro v4.0 — Backend Environment Variables ──

# NVIDIA NIM API Key (get free at build.nvidia.com)
NVIDIA_API_KEY=nvapi-your-key-here

# Database (SQLite on Railway persistent volume)
DATABASE_URL=sqlite:////data/btst_history.db

# Redis (leave empty for in-memory dict — fine for Railway free tier)
REDIS_URL=

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Server
PORT=8000
LOG_LEVEL=INFO

# Feature flags
ENABLE_LLM=true
ENABLE_SENTIMENT=true
ENABLE_OPTION_CHAIN=true
